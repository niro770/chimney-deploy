{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.*)\.(css|js|woff2|woff|ttf|png|jpg|jpeg|gif|ico|svg|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/chimney-cleaning", "destination": "/chimney-cleaning/", "permanent": true },
    { "source": "/chimney-inspection", "destination": "/chimney-inspection/", "permanent": true },
    { "source": "/chimney-repair", "destination": "/chimney-repair/", "permanent": true },
    { "source": "/chimney-lining", "destination": "/chimney-lining/", "permanent": true },
    { "source": "/chimney-caps", "destination": "/chimney-caps/", "permanent": true },
    { "source": "/masonry-repair", "destination": "/masonry-repair/", "permanent": true },
    { "source": "/locations", "destination": "/locations/", "permanent": true }
  ]
}